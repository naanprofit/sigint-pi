# SIGINT-Pi Configuration
# Copy this file to /etc/sigint-pi/config.toml or ./config.toml

[device]
name = "sigint-pi-01"
location_name = "home"

[wifi]
enabled = true
interface = "wlan1"  # External adapter for monitor mode
scan_interval_ms = 5000
rssi_threshold = -80
attack_detection = true
pcap_enabled = true
pcap_path = "/var/lib/sigint-pi/pcap"
pcap_rotate_mb = 100

[bluetooth]
enabled = true
scan_interval_ms = 10000
rssi_threshold = -90
detect_airtags = true

[gps]
enabled = true
gpsd_host = "127.0.0.1"
gpsd_port = 2947
update_interval_ms = 1000

[database]
path = "/var/lib/sigint-pi/sigint.db"
retention_days = 30

[web]
enabled = true
bind_address = "0.0.0.0"
port = 8080

[learning]
enabled = true
training_hours = 24
anomaly_threshold = 0.7
geofence_radius_meters = 100.0

[power]
low_power_mode = false
battery_scan_interval_ms = 15000
ac_scan_interval_ms = 5000

# Alert Configuration
# Fill in your credentials for each service you want to use

[alerts.telegram]
enabled = false
bot_token = "YOUR_BOT_TOKEN"  # Get from @BotFather
chat_id = "YOUR_CHAT_ID"      # Get from @userinfobot

[alerts.twilio]
enabled = false
account_sid = "YOUR_ACCOUNT_SID"
auth_token = "YOUR_AUTH_TOKEN"
from_number = "+1234567890"
to_number = "+1234567890"

[alerts.email]
enabled = false
smtp_host = "smtp.gmail.com"
smtp_port = 587
smtp_user = "your-email@gmail.com"
smtp_password = "your-app-password"
from_address = "your-email@gmail.com"
to_addresses = ["alerts@example.com"]

[alerts.mqtt]
enabled = false
broker_host = "localhost"
broker_port = 1883
client_id = "sigint-pi"
topic_prefix = "sigint"
# username = "optional-username"
# password = "optional-password"

# Sound Alerts
# Audio alerts for events (disable with ninja_mode for silent operation)
[alerts.sound]
enabled = false
ninja_mode = false        # Silent mode - disables ALL audio
volume = 70               # 0-100
new_device_sound = true   # Play sound on new device detection
tracker_sound = true      # Play sound on tracker (AirTag/Tile) detection
attack_sound = true       # Play sound on attack detection
geofence_sounds = true    # Play sound on geofence enter/exit
sounds_dir = "/app/sounds"

# Signal Messenger (End-to-End Encrypted)
# Requires signal-cli to be installed and registered
# See: https://github.com/AsamK/signal-cli
[alerts.signal]
enabled = false
sender_number = "+1234567890"          # Your registered Signal number
recipients = ["+1234567890"]           # Recipients to notify
signal_cli_path = "/usr/local/bin/signal-cli"
config_dir = "/etc/sigint-pi/signal"
use_jsonrpc = false                    # Use signal-cli daemon for faster sending
jsonrpc_socket = "/var/run/signal-cli/socket"
min_priority = "high"                  # low, medium, high, critical
rate_limit_per_hour = 30

# OpenClaw Integration
# Centralized alert aggregation platform for multiple SIGINT-Pi devices
# See documentation for API setup
[alerts.openclaw]
enabled = false
api_url = "https://api.openclaw.io/v1/alerts"
api_key = "YOUR_OPENCLAW_API_KEY"
device_id = "sigint-pi-001"            # Unique ID for this device
device_name = "SIGINT-Pi Living Room"  # Human-readable name
tags = ["home", "primary"]             # Tags for organizing devices
include_raw_data = false               # Include full device data in alerts
min_priority = "medium"                # low, medium, high, critical

# Custom Webhooks
# Send alerts to any HTTP endpoint
[alerts.webhook]
enabled = false

# Example webhook endpoint:
# [[alerts.webhook.endpoints]]
# name = "my-webhook"
# url = "https://example.com/webhook"
# method = "POST"
# auth = { type = "bearer", token = "secret" }
# payload_format = "json"  # json, slack, discord, openclaw, custom
# timeout_secs = 30
# min_priority = "medium"

# InfluxDB Cloud Export (Optional)
# For time-series metrics and Grafana dashboards
[influxdb]
enabled = false
url = "http://localhost:8086"  # Or your InfluxDB Cloud URL
token = "YOUR_INFLUXDB_TOKEN"
org = "your-org"
bucket = "sigint"
