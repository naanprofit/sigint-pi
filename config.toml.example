# SIGINT-Deck Configuration
# Copy this file to ~/sigint-deck/config.toml

[device]
name = "sigint-deck-01"
location_name = "home"

[wifi]
enabled = true
interface = "wlan1"  # External adapter for monitor mode
scan_interval_ms = 5000
rssi_threshold = -80
attack_detection = true
pcap_enabled = true
pcap_path = "/var/lib/sigint-pi/pcap"
pcap_rotate_mb = 100

[bluetooth]
enabled = true
scan_interval_ms = 10000
rssi_threshold = -90
detect_airtags = true

[gps]
enabled = true
gpsd_host = "127.0.0.1"
gpsd_port = 2947
update_interval_ms = 1000

[database]
path = "/var/lib/sigint-pi/sigint.db"
retention_days = 30

[web]
enabled = true
bind_address = "0.0.0.0"
port = 8080

[learning]
enabled = true
training_hours = 1              # Hours to learn baseline (1 = faster, 24 = thorough)
anomaly_threshold = 0.7         # Score > this = anomalous (0.0-1.0)
geofence_radius_meters = 100.0  # Distance to trigger location change

[power]
low_power_mode = false
battery_scan_interval_ms = 15000
ac_scan_interval_ms = 5000

# Alert Configuration
# Fill in your credentials for each service you want to use

[alerts.telegram]
enabled = false
bot_token = "YOUR_BOT_TOKEN"  # Get from @BotFather
chat_id = "YOUR_CHAT_ID"      # Get from @userinfobot

[alerts.twilio]
enabled = false
account_sid = "YOUR_ACCOUNT_SID"
auth_token = "YOUR_AUTH_TOKEN"
from_number = "+1234567890"
to_number = "+1234567890"

[alerts.email]
enabled = false
smtp_host = "smtp.gmail.com"
smtp_port = 587
smtp_user = "your-email@gmail.com"
smtp_password = "your-app-password"
from_address = "your-email@gmail.com"
to_addresses = ["alerts@example.com"]

[alerts.mqtt]
enabled = false
broker_host = "localhost"
broker_port = 1883
client_id = "sigint-pi"
topic_prefix = "sigint"
# username = "optional-username"
# password = "optional-password"

# Sound Alerts
# Audio alerts for events (disable with ninja_mode for silent operation)
[alerts.sound]
enabled = false
ninja_mode = false        # Silent mode - disables ALL audio
volume = 70               # 0-100
new_device_sound = true   # Play sound on new device detection
tracker_sound = true      # Play sound on tracker (AirTag/Tile) detection
attack_sound = true       # Play sound on attack detection
geofence_sounds = true    # Play sound on geofence enter/exit
sounds_dir = "/app/sounds"

# Signal Messenger (End-to-End Encrypted)
# Requires signal-cli to be installed and registered
# See: https://github.com/AsamK/signal-cli
[alerts.signal]
enabled = false
sender_number = "+1234567890"          # Your registered Signal number
recipients = ["+1234567890"]           # Recipients to notify
signal_cli_path = "/usr/local/bin/signal-cli"
config_dir = "/etc/sigint-pi/signal"
use_jsonrpc = false                    # Use signal-cli daemon for faster sending
jsonrpc_socket = "/var/run/signal-cli/socket"
min_priority = "high"                  # low, medium, high, critical
rate_limit_per_hour = 30

# OpenClaw Integration
# Centralized alert aggregation platform for multiple SIGINT-Pi devices
# See documentation for API setup
[alerts.openclaw]
enabled = false
api_url = "https://api.openclaw.io/v1/alerts"
api_key = "YOUR_OPENCLAW_API_KEY"
device_id = "sigint-pi-001"            # Unique ID for this device
device_name = "SIGINT-Pi Living Room"  # Human-readable name
tags = ["home", "primary"]             # Tags for organizing devices
include_raw_data = false               # Include full device data in alerts
min_priority = "medium"                # low, medium, high, critical

# Custom Webhooks
# Send alerts to any HTTP endpoint
[alerts.webhook]
enabled = false

# Example webhook endpoint:
# [[alerts.webhook.endpoints]]
# name = "my-webhook"
# url = "https://example.com/webhook"
# method = "POST"
# auth = { type = "bearer", token = "secret" }
# payload_format = "json"  # json, slack, discord, openclaw, custom
# timeout_secs = 30
# min_priority = "medium"

# ═══════════════════════════════════════════════════════════════════════════════
# LLM Integration (Optional) - AI-powered device analysis
# ═══════════════════════════════════════════════════════════════════════════════
#
# PRIVACY RECOMMENDATION: Use LOCAL LLMs when possible!
# Local LLMs keep all data on your device - nothing is sent to the cloud.
# Cloud providers (OpenAI, Anthropic, xAI) will receive device MACs and network info.
#
# RECOMMENDED LOCAL MODELS:
#   Steam Deck (16GB):  phi3:mini (2.3GB), llama3.2:3b (2GB), qwen2.5:3b (2GB)
#   Raspberry Pi 5:     tinyllama (637MB), qwen2.5:0.5b (400MB)
#   Pi Zero 2W:         tinyllama (637MB) only
#
# QUICK START (Ollama):
#   curl -fsSL https://ollama.ai/install.sh | sh
#   ollama pull phi3:mini
#   ollama serve
#
# ═══════════════════════════════════════════════════════════════════════════════
[llm]
enabled = false
# Provider: ollama, llamacpp, openai, anthropic, xai
# LOCAL (recommended):  ollama, llamacpp
# CLOUD (privacy risk): openai, anthropic, xai
provider = "ollama"
endpoint = "http://localhost:11434"          # Ollama default
model = "phi3:mini"                          # Recommended for Steam Deck
# api_key = ""                               # Not needed for local LLMs
max_tokens = 200
timeout_secs = 60

# ─────────────────────────────────────────────────────────────────────────────
# ALTERNATIVE: llama.cpp (more control, manual model loading)
# ─────────────────────────────────────────────────────────────────────────────
# [llm]
# enabled = true
# provider = "llamacpp"
# endpoint = "http://localhost:8080"
# model = "local"
# max_tokens = 200
# timeout_secs = 60

# ─────────────────────────────────────────────────────────────────────────────
# CLOUD PROVIDERS (use only if local LLM not feasible)
# WARNING: Device MACs and network data sent to cloud servers
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude
# [llm]
# enabled = true
# provider = "anthropic"
# endpoint = "https://api.anthropic.com"
# model = "claude-3-haiku-20240307"
# api_key = "sk-ant-api..."             # Get from console.anthropic.com
# max_tokens = 200
# timeout_secs = 60

# xAI Grok
# [llm]
# enabled = true
# provider = "xai"
# endpoint = "https://api.x.ai"
# model = "grok-2"
# api_key = "xai-..."                   # Get from console.x.ai
# max_tokens = 200
# timeout_secs = 60

# OpenAI
# [llm]
# enabled = true
# provider = "openai"
# endpoint = "https://api.openai.com"
# model = "gpt-4o-mini"
# api_key = "sk-..."                    # Get from platform.openai.com
# max_tokens = 200
# timeout_secs = 60

# InfluxDB Cloud Export (Optional)
# For time-series metrics and Grafana dashboards
[influxdb]
enabled = false
url = "http://localhost:8086"  # Or your InfluxDB Cloud URL
token = "YOUR_INFLUXDB_TOKEN"
org = "your-org"
bucket = "sigint"

# ═══════════════════════════════════════════════════════════════════════════════
# OpenClaw Mesh Networking - Share threats with other nodes
# ═══════════════════════════════════════════════════════════════════════════════
[openclaw]
enabled = false
webhook_url = "https://your-openclaw-server.com/api/alerts"
# api_key = "your-api-key"

# Relay Mode - Share threats with other OpenClaw nodes
relay_enabled = false
relay_min_level = "high"        # low, medium, high, critical
relay_listen_port = 8081        # Port to receive relayed threats
peers = [                       # Other OpenClaw nodes to sync with
    # "http://192.168.1.100:8081",
    # "http://192.168.1.101:8081",
]
include_location = false        # Include GPS coords in relayed messages
relay_categories = []           # Empty = all categories; or ["surveillance", "tracker"]

# ═══════════════════════════════════════════════════════════════════════════════
# Meshtastic LoRa Mesh Integration
# Share threat alerts over LoRa mesh network for off-grid operation
# ═══════════════════════════════════════════════════════════════════════════════
[meshtastic]
enabled = false
# Connection type: "mqtt" (recommended), "serial", "tcp"
connection_type = "mqtt"

# MQTT Bridge (easiest setup - works with public Meshtastic MQTT)
mqtt_broker = "mqtt.meshtastic.org"
mqtt_topic = "msh/US/2/json"

# Serial connection (direct USB to Meshtastic device)
# serial_port = "/dev/ttyUSB0"

# TCP connection (Meshtastic device with WiFi)
# tcp_host = "192.168.1.50"
# tcp_port = 4403

min_threat_level = "high"       # Only send high/critical threats
compact_messages = true         # Short messages for LoRa bandwidth
channel = 0                     # Meshtastic channel (0-7)

# ═══════════════════════════════════════════════════════════════════════════════
# EFF RayHunter - IMSI Catcher / Stingray Detection
# Requires rooted Pixel phone running RayHunter connected via USB
# https://github.com/EFForg/rayhunter
# ═══════════════════════════════════════════════════════════════════════════════
[rayhunter]
enabled = false
api_url = "http://localhost:8080"   # RayHunter API (via ADB forward)
poll_interval_secs = 5              # How often to check for threats
alert_on_suspicious = true          # Alert on any suspicious activity
relay_to_openclaw = true            # Forward alerts to OpenClaw
relay_to_meshtastic = false         # Forward alerts to Meshtastic
# alert_template = "🚨 IMSI CATCHER: {confidence}% confidence, Cell: {cid}"

# ═══════════════════════════════════════════════════════════════════════════════
# SDR (Software Defined Radio) - RF Spectrum Monitoring
# Supports RTL-SDR, HackRF, LimeSDR
# ═══════════════════════════════════════════════════════════════════════════════
[sdr]
enabled = false
device_type = "rtlsdr"          # rtlsdr, hackrf, limesdr
device_index = 0
sample_rate = 2400000           # 2.4 MHz
gain = 0                        # 0 = auto

# Frequencies to monitor (Hz)
monitor_frequencies = [
    462562500,    # FRS/GMRS Channel 1
    462587500,    # FRS/GMRS Channel 2
    467562500,    # FRS Channel 8
    154570000,    # Police common
    155475000,    # Police common
    460000000,    # Public safety
]

# Auto-scan mode (sweep frequency range)
auto_scan = false
# scan_range = [400000000, 470000000, 25000]  # start, end, step (Hz)

signal_threshold_db = -50.0     # Alert on signals above this level
