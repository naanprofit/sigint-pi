# timeout_secs = 60

# InfluxDB Cloud Export (Optional)
# For time-series metrics and Grafana dashboards
[influxdb]
enabled = false
url = "http://localhost:8086"  # Or your InfluxDB Cloud URL
token = "YOUR_INFLUXDB_TOKEN"
org = "your-org"
bucket = "sigint"
